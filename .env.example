# Salin berkas ini menjadi .env, lalu isi nilainya.
# Berkas .env sudah masuk .gitignore dan tidak boleh di-commit.

# Token akses Hugging Face untuk memuat pyannote/speaker-diarization-3.1
# Terbitkan di: https://huggingface.co/settings/tokens (izin Read sudah cukup)
# Wajib juga menyetujui syarat model di halaman model pyannote.
HUGGINGFACE_TOKEN=

# API key Google Gemini untuk modul evaluasi LLM (evaluator.py)
# Terbitkan di: https://aistudio.google.com/apikey
# Kunci baru berformat "AQ.Ab..." (Auth key). Kunci lama "AIza..." (Standard
# key) sedang dipensiunkan Google dan berhenti berfungsi September 2026.
GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# Pengaturan opsional di bawah ini SENGAJA dikomentari.
# Jangan menuliskannya sebagai baris kosong (mis. "DB_PATH="): baris seperti
# itu membuat variabel ADA tetapi bernilai kosong, sehingga nilai default di
# kode tidak terpakai. Untuk DB_PATH akibatnya fatal -- sqlite3 memakai basis
# data sementara yang terhapus sendiri, dan seluruh hasil evaluasi hilang
# meski sistem melaporkan penyimpanan berhasil.
# Biarkan dikomentari untuk memakai default, atau isi dengan nilai sungguhan.
# ---------------------------------------------------------------------------

# Model Gemini yang dipakai sebagai evaluator. Default: gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash

# Lokasi berkas basis data SQLite. Default: evaluasi.db
# DB_PATH=evaluasi.db
