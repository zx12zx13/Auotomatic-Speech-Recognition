# Salin berkas ini menjadi .env, lalu isi nilainya.
# Berkas .env sudah masuk .gitignore dan tidak boleh di-commit.

# Token akses Hugging Face untuk memuat pyannote/speaker-diarization-3.1
# Terbitkan di: https://huggingface.co/settings/tokens
# Wajib juga menyetujui syarat model di halaman model pyannote.
HUGGINGFACE_TOKEN=

# API key Google Gemini untuk modul evaluasi LLM (evaluator.py)
# Terbitkan di: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Opsional. Model Gemini yang dipakai sebagai evaluator.
# Kosongkan untuk memakai default: gemini-2.5-flash
GEMINI_MODEL=
